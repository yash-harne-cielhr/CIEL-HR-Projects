# ===== EzyComp PRODUCTION environment =====
# Copy this file to ".env.production" and fill in real values.
# ".env.production" itself is gitignored - never commit real credentials.
#
# IMPORTANT: do NOT include a trailing slash on the URL.
#   Correct:   https://ezycomp.ur-nl.com
#   Incorrect: https://ezycomp.ur-nl.com/

REACT_APP_URL=

# Single test user for now - just enough to prove the Login page works.
# We'll introduce role-specific users when we build out actual modules.
TEST_USER_USERNAME=
TEST_USER_PASSWORD=
